PORT=5000
NODE_ENV=development

# Get this from MongoDB Atlas -> Connect -> Drivers
MONGO_URI=mongodb+srv://<username>:<password>@cluster0.mongodb.net/amar-school

# Any long random string
JWT_SECRET=replace_with_a_long_random_secret
JWT_EXPIRES_IN=7d

CLIENT_URL=http://localhost:3000

# Gmail address + an "App Password" (not your normal Gmail password)
EMAIL_USER=your_email@gmail.com
EMAIL_PASS=your_app_password

# Used once by the seed script to create the first Super Admin
SUPERADMIN_NAME=Super Admin
SUPERADMIN_EMAIL=superadmin@amarschool.com
SUPERADMIN_PASSWORD=ChangeThisPassword123
